{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dragonboat.dev/schemas/v0/evidence-bundle.schema.json",
  "title": "DragonBoat Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "task_id",
    "run_id",
    "submitted_by",
    "status",
    "summary",
    "changed_files",
    "commands_run",
    "checks",
    "risks",
    "unresolved_questions"
  ],
  "properties": {
    "schema_version": {
      "const": "dragonboat.evidence_bundle.v0"
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^evidence_[A-Za-z0-9_-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_-]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9_-]+$"
    },
    "submitted_by": {
      "$ref": "#/$defs/agent_ref"
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "blocked",
        "partial"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/changed_file"
      }
    },
    "commands_run": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command_result"
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check_result"
      }
    },
    "mailbox_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^msg_[A-Za-z0-9_-]+$"
      },
      "default": []
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "default": []
    },
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "unresolved_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "$defs": {
    "agent_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "platform"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^agent_[A-Za-z0-9_-]+$"
        },
        "role": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        }
      }
    },
    "changed_file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "change_type",
        "summary"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "change_type": {
          "type": "string",
          "enum": [
            "added",
            "modified",
            "deleted",
            "renamed"
          ]
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "command_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "cwd",
        "exit_code",
        "summary"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "exit_code": {
          "type": "integer"
        },
        "summary": {
          "type": "string"
        },
        "log_ref": {
          "type": "string"
        }
      }
    },
    "check_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "skipped"
          ]
        },
        "details": {
          "type": "string"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "log",
            "screenshot",
            "diff",
            "report",
            "recording"
          ]
        },
        "path": {
          "type": "string"
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "description"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "description": {
          "type": "string"
        },
        "mitigation": {
          "type": "string"
        }
      }
    }
  }
}
